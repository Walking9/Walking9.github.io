.about-widget
  .about-avatar
    text-align: center
    margin-bottom: 15px
    img
      width: 120px
      height: 120px
      border-radius: 60px
      border: 3px solid #eee
      transition: all 0.3s ease
      &:hover
        transform: scale(1.05)
        border-color: color-link
  
  .about-info
    margin-bottom: 15px
    ul
      li
        margin-bottom: 8px
        i
          margin-right: 8px
          color: color-link
  
  .about-description
    p
      text-align: justify
      line-height: 1.6